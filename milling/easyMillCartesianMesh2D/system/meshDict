FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      meshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

surfaceFile     "geom.fms";

workflowControls
{
  // stopAfter boundaryLayerRefinement;
  // stopAfter boundaryLayerGeneration;
}
 
maxCellSize     .5e-3;

objectRefinements
{
    zone1refiment // top - closest to the inlet  
    {
        type        hollowCone;
        additionalRefinementLevels 1; 
        p0               (0. 20e-3 0.);
        p1               (0. 70e-3 0.);
        radius0_Inner    10e-3;
        radius0_Outer    15e-3;
        radius1_Inner    10e-3;
        radius1_Outer    15e-3;
    }

    zone2refiment // first widening after inlet  
    {
        type        hollowCone;
        additionalRefinementLevels 1; 
        p0               (0. -5e-3  0.);
        p1               (0. 20e-3 0.);
        radius0_Inner    35e-3;
        radius0_Outer    80e-3;
        radius1_Inner    10e-3;
        radius1_Outer    15e-3;
    }

    zone3refiment // second widening after inlet  
    {
        type        hollowCone;
        additionalRefinementLevels 2; 
        p0               (0. -5e-3  0.);
        p1               (0. 20e-3 0.);
        radius0_Inner    60e-3;
        radius0_Outer    80e-3;
        radius1_Inner    60e-3;
        radius1_Outer    80e-3;
    }

    zone4refiment // bottom - closest to the rotor 
    {
        type        hollowCone;
        additionalRefinementLevels 1; 
        p0               (0. -1e-4 0.);
        p1               (0. 0. 0.);
        radius0_Inner     0.;
        radius0_Outer     80e-3;
        radius1_Inner     0.;
        radius1_Outer     80e-3;
    }

} 

